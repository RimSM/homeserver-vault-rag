# cp .env.example .env  (.env는 git 제외)
VAULT_PATH=/Users/rimsm/second-brain
# 실행=prod(맥미니). Tailscale IP. stage 로컬 튜닝 시엔 localhost.
OLLAMA_URL=http://100.83.140.46:11434
EMBED_MODEL=bge-m3      # 한국어 RAG 실용 기본값 (dim 1024). nomic-embed-text 는 한국어 약함.
EMBED_DIM=1024
INDEX_BATCH=100         # 재인덱싱 배치 commit 크기
# 공용 infra Postgres. 비번은 infra/.env 의 VAULT_RAG_DB_PASSWORD 와 동일.
PGHOST=100.83.140.46
PGPORT=5432
PGDATABASE=vault_rag
PGUSER=vault_rag_app
PGPASSWORD=CHANGE_ME
